# Local Development Configuration
# Copy this file to .env.local and fill in your values.
# Get your dev API key from: Dashboard > Websites > [Your Site] > Local Development

NEXT_PUBLIC_WIDGET_API_KEY=vk_dev_your_key_here
NEXT_PUBLIC_WIDGET_HOST=https://app.mobeus.ai

# MCP server URL for direct browser-side tool invocation (bypasses LLM/Mobeus for LinkedIn fetch).
# Set this to the publicly accessible MCP server URL for your deployment.
# Example: https://your-trainco-instance.rapidprototype.ai
# The browser calls {NEXT_PUBLIC_MCP_SERVER_URL}/mcp/sse directly via EventSource + JSON-RPC 2.0.
# The MCP server must allow CORS from the hosting domain (default config allows all origins).
NEXT_PUBLIC_MCP_SERVER_URL=
