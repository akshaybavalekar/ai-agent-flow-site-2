# Local Development Configuration
# Copy this file to .env.local and fill in your values.
# Get your dev API key from: Dashboard > Websites > [Your Site] > Local Development

NEXT_PUBLIC_WIDGET_API_KEY=vk_dev_your_key_here
NEXT_PUBLIC_WIDGET_HOST=https://app.mobeus.ai

# Base URL for direct MCP REST calls (Express proxy: POST /api/invoke/{toolName}).
# When set, the SPA calls find_candidate → get_candidate → get_jobs_by_skills →
# get_skill_progression directly on LinkedIn click, bypassing the Mobeus LLM for
# data fetches and reducing onboarding latency significantly.
# Leave blank to use the Mobeus-proxied /api/invoke/* routes (relative URLs).
NEXT_PUBLIC_MCP_API_BASE=https://train-v1.rapidprototype.ai
