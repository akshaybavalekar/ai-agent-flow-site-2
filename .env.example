# Local Development Configuration
# Copy this file to .env.local and fill in your values.
# Get your dev API key from: Dashboard > Websites > [Your Site] > Local Development

NEXT_PUBLIC_WIDGET_API_KEY=vk_dev_your_key_here
NEXT_PUBLIC_WIDGET_HOST=https://app.mobeus.ai

# MCP server base URL for direct LinkedIn onboarding calls (SSE + JSON-RPC 2.0).
# The SPA opens an SSE session and calls find_candidate / get_candidate directly,
# bypassing the Mobeus LLM for data fetches to reduce latency.
NEXT_PUBLIC_MCP_BASE_URL=https://train-v1.rapidprototype.ai/mcp
